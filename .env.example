# ─────────────────────────────────────────────────────────────────────────────
# Mpingi Market — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Datadog RUM — optional (leave blank to disable monitoring)
# Get these from: Datadog → UX Monitoring → RUM Applications → New Application
VITE_DD_CLIENT_TOKEN=
VITE_DD_APP_ID=
